# Coinbase Developer Platform API Credentials
# Get yours at: https://developer.coinbase.com
COINBASE_API_KEY=your_api_key_here
COINBASE_API_SECRET=your_api_secret_here

# Network Configuration
# Options: base, ethereum, solana
AGENTIC_WALLET_NETWORK=base

# Spending Limits (in USD)
MAX_SESSION_SPEND=100
MAX_SINGLE_TX=50
DAILY_SPEND_LIMIT=500

# Trading Configuration
DEFAULT_SLIPPAGE=0.5
ENABLE_AUTO_TRADE=false

# Alert Settings
ALERT_THRESHOLD=20

# Logging
LOG_LEVEL=info
LOG_TO_FILE=true

# Optional: Sentry for error tracking
# SENTRY_DSN=your_sentry_dsn_here
